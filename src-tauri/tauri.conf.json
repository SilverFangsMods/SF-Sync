{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SF-Sync",
  "version": "0.1.18",
  "identifier": "com.silverfangs.sync",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-rclone.ps1 && bun run build",
    "beforeBundleCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sign-exe.ps1",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SF-Sync",
        "width": 760,
        "height": 560,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "resources": ["resources/rclone.exe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": "0D3CB1133F15D22115F7D531088A5BB514E9523F",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  }
}
